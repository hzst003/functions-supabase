// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MaterialList {
  id         String   @id @default(uuid()) @db.Uuid

  项目名称   String?
  品名       String
  材料编号   String
  规格       String?
  数量       Decimal  @db.Decimal(12, 4)
  单位       String   @default("")

  @@map("material_lists")
}

model ProjectInfo {
  id              String    @id @default(uuid()) @db.Uuid
  code            String    @unique // 编号
  projectName     String    // 名称
  constructionUnit String?  // 施工单位
  workflow        String?   // 所属流程
  initiatedAt     DateTime? // 发起时间
  initiator       String?   // 发起人员
  approvalNode    String?   // 审批节点
  urgencyLevel    String?   // 紧急程度
  reviewStatus    String?   // 审核状态
  receivedAt      DateTime? // 接收时间
}